-- Задание 2
SELECT track_name, duration
FROM tracks
WHERE duration = (SELECT MAX(duration) FROM tracks);

SELECT track_name
FROM tracks
WHERE duration >= 210;

SELECT compilation_name
FROM compilations
WHERE release_year BETWEEN 2018 AND 2020;

SELECT artist_name
FROM artists
WHERE artist_name NOT LIKE '% %';

SELECT track_name
FROM tracks
WHERE track_name ILIKE 'мой %'
   OR track_name ILIKE '% мой'
   OR track_name ILIKE '% мой %'
   OR track_name ILIKE 'мой'
   OR track_name ILIKE 'my %'
   OR track_name ILIKE '% my'
   OR track_name ILIKE '% my %'
   OR track_name ILIKE 'my';

SELECT track_name
FROM tracks
WHERE string_to_array(lower(track_name), ' ') && ARRAY['мой', 'my'];

-- Задание 3
SELECT g.genre_name,
       COUNT(ag.artist_id) AS artist_count
FROM genres g
JOIN artist_genres ag ON g.genre_id = ag.genre_id
GROUP BY g.genre_id, g.genre_name
ORDER BY artist_count DESC, g.genre_name;

SELECT COUNT(t.track_id) AS track_count
FROM tracks t
JOIN albums a ON t.album_id = a.album_id
WHERE a.release_year BETWEEN 2019 AND 2020;

SELECT a.album_name,
       ROUND(AVG(t.duration), 2) AS avg_duration_seconds
FROM albums a
JOIN tracks t ON a.album_id = t.album_id
GROUP BY a.album_id, a.album_name
ORDER BY a.album_name;

SELECT ar.artist_name
FROM artists ar
WHERE ar.artist_id NOT IN (
    SELECT aa.artist_id
    FROM artist_albums aa
    JOIN albums a ON aa.album_id = a.album_id
    WHERE a.release_year = 2020
)
ORDER BY ar.artist_name;

SELECT DISTINCT c.compilation_name
FROM compilations c
JOIN compilation_tracks ct ON c.compilation_id = ct.compilation_id
JOIN tracks t ON ct.track_id = t.track_id
JOIN albums a ON t.album_id = a.album_id
JOIN artist_albums aa ON a.album_id = aa.album_id
JOIN artists ar ON aa.artist_id = ar.artist_id
WHERE ar.artist_name = 'Dabro'
ORDER BY c.compilation_name;

-- Задание 4
SELECT DISTINCT a.album_name
FROM albums a
JOIN artist_albums aa ON a.album_id = aa.album_id
JOIN artist_genres ag ON aa.artist_id = ag.artist_id
GROUP BY a.album_id, a.album_name, aa.artist_id
HAVING COUNT(DISTINCT ag.genre_id) > 1
ORDER BY a.album_name;

SELECT t.track_name
FROM tracks t
LEFT JOIN compilation_tracks ct ON t.track_id = ct.track_id
WHERE ct.track_id IS NULL
ORDER BY t.track_name;

SELECT DISTINCT ar.artist_name
FROM artists ar
JOIN artist_albums aa ON ar.artist_id = aa.artist_id
JOIN albums a ON aa.album_id = a.album_id
JOIN tracks t ON a.album_id = t.album_id
WHERE t.duration = (
    SELECT MIN(duration)
    FROM tracks
)
ORDER BY ar.artist_name;

SELECT a.album_name
FROM albums a
JOIN tracks t ON a.album_id = t.album_id
GROUP BY a.album_id, a.album_name
HAVING COUNT(t.track_id) = (
    SELECT MIN(track_count)
    FROM (
        SELECT COUNT(t2.track_id) AS track_count
        FROM albums a2
        JOIN tracks t2 ON a2.album_id = t2.album_id
        GROUP BY a2.album_id
    ) sub
)
ORDER BY a.album_name;
